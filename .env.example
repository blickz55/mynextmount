# Copy to .env.local (gitignored). Next.js and data scripts read .env.local —
# do NOT put real secrets in this file; leave placeholders here only.
# https://develop.battle.net/access/clients

# Site / deploy — canonical URL for metadata (Open Graph, metadataBase). Vercel: set in Project → Environment Variables.
# NEXT_PUBLIC_SITE_URL=https://www.mynextmount.com

# Epic I.1 — CurseForge / Wago project page for MyNextMount (How To + coming soon). If unset, the site links to CurseForge search for the name.
# NEXT_PUBLIC_ADDON_LISTING_URL=https://www.curseforge.com/wow/addons/...

BLIZZARD_CLIENT_ID=
BLIZZARD_CLIENT_SECRET=

# Optional: us | eu | kr | tw
BLIZZARD_REGION=us

# Optional: ms between mount detail fetches (default 1000; Epic B.0 rate posture)
# COVERAGE_FETCH_DELAY_MS=1000

# Epic B.6 — npm run data:check-drift (falls back to COVERAGE_FETCH_DELAY_MS)
# DRIFT_FETCH_DELAY_MS=1000

# Epic C.4 — optional LLM draft for data/farm-tips.json (NOT used by data:build)
# FARM_TIP_OPENAI_API_KEY=
# FARM_TIP_LLM_MODEL=gpt-4o-mini
# FARM_TIP_OPENAI_BASE_URL=https://api.openai.com/v1

# npm run content:guides-refine-checklists — rewrite checklists only (remove “open Wowhead” filler); reuses CONTENT_GUIDES_* / OPENAI_API_KEY
#
# Maintainer batch — npm run content:guides-batch (LLM guides from mounts.json metadata; NOT data:build)
# Any one of: OPENAI_API_KEY, FARM_TIP_OPENAI_API_KEY, or CONTENT_GUIDES_OPENAI_API_KEY
# OPENAI_API_KEY=
# CONTENT_GUIDES_OPENAI_API_KEY=
# CONTENT_GUIDES_LLM_MODEL=gpt-4o-mini
# CONTENT_GUIDES_OPENAI_BASE_URL=https://api.openai.com/v1
# CONTENT_GUIDES_LLM_DELAY_MS=900

# Epic D.5 — npm run wowhead-digest:draft (paraphrase top-comment excerpts → wowhead-comment-digests.json)
# Reuses FARM_TIP_* if WOWHEAD_DIGEST_* unset:
# WOWHEAD_DIGEST_OPENAI_API_KEY=
# WOWHEAD_DIGEST_LLM_MODEL=gpt-4o-mini
# WOWHEAD_DIGEST_OPENAI_BASE_URL=https://api.openai.com/v1
# WOWHEAD_DIGEST_LLM_DELAY_MS=750

# npm run content:mount-flavor-batch — OpenAI flavor + “how to obtain” bullets → wowhead-comment-digests.json (no Wowhead scraping)
# Reuses WOWHEAD_DIGEST_* / FARM_TIP_* / OPENAI_API_KEY if MOUNT_FLAVOR_* unset:
# MOUNT_FLAVOR_OPENAI_API_KEY=
# MOUNT_FLAVOR_LLM_MODEL=gpt-4o-mini
# MOUNT_FLAVOR_OPENAI_BASE_URL=https://api.openai.com/v1
# MOUNT_FLAVOR_LLM_DELAY_MS=900

# Epic B.2 — npm run data:build
# BUILD_FETCH_DELAY_MS=1000
# BUILD_CACHE_TTL_SECONDS=86400
# BUILD_AS_OF_PATCH=retail-11.x.x

# Epic B.3 — npm run data:spell-baseline (falls back to BUILD_* if unset)
# SPELL_BASELINE_FETCH_DELAY_MS=1000
# SPELL_BASELINE_CACHE_TTL_SECONDS=86400

# Epic B.4 — npm run data:enrich-metadata (spell + media → iconFileId)
# ENRICH_METADATA_DELAY_MS=1000  # after each live fetch (incl. spell 404); skipped on cache hit
# ENRICH_METADATA_CACHE_TTL_SECONDS=604800

# Epic D.6 — npm run data:check-surface (static surface audit; use --strict for gate)
# SURFACE_MIN_ICON_PCT=95
# SURFACE_MIN_WOWHEAD_PCT=100
# SURFACE_MIN_COMMENTS_PCT=100
# SURFACE_MIN_DIGEST_PCT=0
# SURFACE_MIN_FARM_TIP_PCT=0
# SURFACE_MIN_GUIDE_PCT=0
# SURFACE_TOP_MISSING=25

# Epic B.8 — npm run data:sync-spell-icons (Wago SpellMisc + wow-listfile; cached under data/build/cache/spell-icon-map/)
# SPELL_MISC_CSV_URL=https://wago.tools/db2/SpellMisc/csv
# SPELL_ICON_LISTFILE_URL=https://github.com/wowdev/wow-listfile/releases/latest/download/community-listfile.csv
# SPELL_ICON_CACHE_TTL_SEC=604800
